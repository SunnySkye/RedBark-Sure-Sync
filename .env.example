# Copy this file to .env and replace the placeholder values.

# Required for redbark_export_transactions.py and orchestrate_redbark_sync.py
REDBARK_API_KEY=rbk_live_your_redbark_api_key_here

# Required for sure_export_transactions.py, sync_redbark_to_sure.py,
# audit_redbark_to_sure_duplicates.py, and orchestrate_redbark_sync.py
SURE_BASE_URL=https://your-sure-instance.example
SURE_API_KEY=your_sure_api_key_here

# Optional. If duplicates are detected, the audit script posts an alert here.
# Leave blank or remove this line if you do not want webhook alerts.
DUPLICATE_AUDIT_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Optional. Base64-encoded contents of account_map.json.
# generate_account_map.py prints this line after it writes the map file.
# Useful for Docker runs where mounting account_map.json is inconvenient.
REDBARK_SURE_ACCOUNT_MAP_BASE64=